# ============================================================
#  AI INVOICING APP — ENVIRONMENT CONFIG
#  Copy to .env.local for local dev, or set these in Vercel →
#  Project → Settings → Environment Variables.
# ============================================================

# ---- APP PASSWORD (gate for the whole app) ----
# Note: the value contains $ characters. In a .env file, wrap in
# single quotes so the shell does not interpret them.
APP_PASSWORD='$WidenChicago$'

# ---- ANTHROPIC (Claude) — powers scope + line-item generation ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- NOTION — where finalized estimates get logged ----
# Create an internal integration at https://www.notion.so/my-integrations
# then "Connect" it to your CRM database (••• menu → Connections).
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=8f559060-1e02-4c70-8147-0d15798f1174

# ---- NOTION PROPERTY MAPPING (whitelabel: match your DB's columns) ----
NOTION_PROP_NAME=Name
NOTION_PROP_ADDRESS=Address
NOTION_PROP_SUBTOTAL=Subtotal
NOTION_PROP_TAX=Tax
NOTION_PROP_TOTAL=Total
NOTION_PROP_STATUS=Status
NOTION_PROP_DATE=Date
NOTION_PROP_NOTES=Notes
# Optional. Leave blank if your DB has no such column.
# If set (a Number property), invoice numbers are stored & sequenced here.
NOTION_PROP_INVOICE=Invoice No.
# Optional multi-select column for service tags.
NOTION_PROP_SERVICE=Service Type

# ---- INVOICE NUMBERING ----
# Used as the first number if none can be found in Notion yet.
INVOICE_START=737802

# ---- DEFAULTS ----
DEFAULT_TAX_RATE=8.25      # % applied to subtotal (editable per estimate in UI)

# ============================================================
#  BRANDING (whitelabel — all optional, defaults shown)
#  NEXT_PUBLIC_ prefix = available in the browser.
# ============================================================
NEXT_PUBLIC_APP_NAME=AI Invoicing
NEXT_PUBLIC_BRAND_NAME=WIDEN
NEXT_PUBLIC_BRAND_SUB=CHIMNEY & VENT
NEXT_PUBLIC_BRAND_WEBSITE=WidenChicago.com
NEXT_PUBLIC_BRAND_ADDRESS=1500 Old Deerfield Rd, Highland Park, IL
NEXT_PUBLIC_BRAND_PHONE=224 343 1991
NEXT_PUBLIC_DOC_TITLE=CHIMNEY REPAIR ESTIMATE
NEXT_PUBLIC_BRAND_ACCENT=#b35a33
NEXT_PUBLIC_BRAND_TRADE=chimney and venting

# Client-visible default tax rate (prefill in UI)
NEXT_PUBLIC_DEFAULT_TAX_RATE=8.25
